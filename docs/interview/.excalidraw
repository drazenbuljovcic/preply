    {
      "id": "edPRRks0d6X42-oKzX0Pr",
      "type": "text",
      "x": 5171.296423673669,
      "y": 1286.432159956108,
      "width": 791.9193115234375,
      "height": 75,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [
        "zB--943ljFo9_I_q1wyTl",
        "qsdH_nGIrawSJ4g_xRbt5"
      ],
      "frameId": null,
      "index": "b0H",
      "roundness": null,
      "seed": 1399894644,
      "version": 118,
      "versionNonce": 1758593780,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1771942090465,
      "link": null,
      "locked": false,
      "text": "We’re building a new onboarding wizard for our sports trainers\nmarketplace, which connects users with personal trainers across various\ndisciplines.",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "We’re building a new onboarding wizard for our sports trainers marketplace, which connects users with personal trainers across various disciplines.",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "JBVYqhPP1qEnV3LlZplzy",
      "type": "text",
      "x": 5167.496295897891,
      "y": 1380.149519951035,
      "width": 776.3394775390625,
      "height": 50,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [
        "zB--943ljFo9_I_q1wyTl",
        "qsdH_nGIrawSJ4g_xRbt5"
      ],
      "frameId": null,
      "index": "b0I",
      "roundness": null,
      "seed": 890913780,
      "version": 107,
      "versionNonce": 1199232588,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1771942090465,
      "link": null,
      "locked": false,
      "text": "The wizard is designed to match users with the most suitable trainer\nbased on their responses.",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "The wizard is designed to match users with the most suitable trainer based on their responses.",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "EV2wGmiUBlrUQVmTzl-_b",
      "type": "text",
      "x": 5168.321438155151,
      "y": 1455.0931987168003,
      "width": 746.0594482421875,
      "height": 50,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [
        "zB--943ljFo9_I_q1wyTl",
        "qsdH_nGIrawSJ4g_xRbt5"
      ],
      "frameId": null,
      "index": "b0J",
      "roundness": null,
      "seed": 513123700,
      "version": 131,
      "versionNonce": 587039860,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1771942090465,
      "link": null,
      "locked": false,
      "text": "Each step presents a question, which users can either answer or\nskip before continuing to the next step.",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Each step presents a question, which users can either answer or skip before continuing to the next step.",
      "autoResize": false,
      "lineHeight": 1.25
    },
