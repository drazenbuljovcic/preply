      "versionNonce": 774328396,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1771942090465,
      "link": null,
      "locked": false,
      "text": "Functional Requirement:\n- Web\n- Read-heavy\n- supportive feature (supported partial preferences)\n\n\nNon-Functional Requirements:\n- Rendering (CSR, SSR)\n- SEO\n- Auth (already logged in as a student)\n- Accessbility\n- Performance\n- UX (design system)\n- Personalization (CRM)",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Functional Requirement:\n- Web\n- Read-heavy\n- supportive feature (supported partial preferences)\n\n\nNon-Functional Requirements:\n- Rendering (CSR, SSR)\n- SEO\n- Auth (already logged in as a student)\n- Accessbility\n- Performance\n- UX (design system)\n- Personalization (CRM)",
      "autoResize": true,
      "lineHeight": 1.25
